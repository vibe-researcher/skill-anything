{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skill-anything.local/schemas/osr-grader.schema.json",
  "title": "OSR — Grader",
  "description": "Return schema for Grader sub-agent. Typical size 2-4 KB. Long reasoning/feedback text lives on disk (feedback_file, suggestion_file) and is referenced by hash here; Orchestrator does not read the full text in minimal context_mode.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "status",
    "agent_type",
    "agent_env",
    "surprises",
    "anomalies",
    "meta_observations",
    "scores_file",
    "per_task",
    "aggregate",
    "blind_discipline_check"
  ],
  "properties": {
    "status": { "enum": ["success", "partial", "failed", "schema_insufficient"] },
    "agent_type": { "const": "grader" },
    "agent_env": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cwd", "wall_time_s"],
      "properties": {
        "cwd": { "type": "string" },
        "wall_time_s": { "type": "number", "minimum": 0 },
        "tool_use_count_self_report": { "type": "integer", "minimum": 0 }
      }
    },
    "surprises": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["short", "suggested_action", "severity"],
        "properties": {
          "short": { "type": "string", "maxLength": 120 },
          "suggested_action": { "type": "string", "maxLength": 200 },
          "severity": { "enum": ["low", "medium", "high"] },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "anomalies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim"],
        "properties": {
          "claim": { "type": "string", "maxLength": 200 },
          "evidence_path": { "type": "string" }
        }
      }
    },
    "meta_observations": { "type": "array", "items": { "type": "string", "maxLength": 200 } },
    "notes_path": { "type": "string" },
    "notes_topic_tags": { "type": "array", "items": { "type": "string" }, "maxItems": 10 },
    "requested_schema_extension": {
      "type": "object",
      "required": ["field_name", "field_type", "reason"],
      "properties": {
        "field_name": { "type": "string" },
        "field_type": { "type": "string" },
        "reason": { "type": "string", "maxLength": 500 }
      }
    },
    "extras": { "type": "object" },

    "scores_file": {
      "type": "string",
      "description": "Path to the full blind-grader-scores.json (long-form reasoning included) on disk."
    },
    "per_task": {
      "type": "array",
      "description": "One entry per eval task.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["task_id", "winner", "quality_a", "quality_b", "tool_count_a_from_log", "tool_count_b_from_log"],
        "properties": {
          "task_id": { "type": "string" },
          "winner": { "enum": ["A", "B", "TIE"] },
          "quality_a": { "type": "number", "minimum": 1, "maximum": 5 },
          "quality_b": { "type": "number", "minimum": 1, "maximum": 5 },
          "tool_count_a_from_log": { "type": "integer", "minimum": 0 },
          "tool_count_b_from_log": { "type": "integer", "minimum": 0 },
          "feedback_hash": { "type": "string" },
          "suggestion_hash": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "feedback_file": { "type": "string", "description": "Path to feedback corpus (plain text or JSON)." },
    "suggestion_file": { "type": "string", "description": "Path to suggestion corpus." },
    "aggregate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["winner_dist", "quality_a_range", "quality_b_range"],
      "properties": {
        "winner_dist": {
          "type": "object",
          "additionalProperties": false,
          "required": ["A", "B", "TIE"],
          "properties": {
            "A": { "type": "integer", "minimum": 0 },
            "B": { "type": "integer", "minimum": 0 },
            "TIE": { "type": "integer", "minimum": 0 }
          }
        },
        "quality_a_range": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 2,
          "maxItems": 2
        },
        "quality_b_range": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 2,
          "maxItems": 2
        },
        "most_discriminating_task": { "type": "string" },
        "least_discriminating_task": { "type": "string" },
        "suspicious_identity_leaks": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Task IDs where Grader noticed text patterns suggesting one side explicitly referenced Skill files."
        }
      }
    },
    "blind_discipline_check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["referenced_skill_files", "inferred_identity"],
      "properties": {
        "referenced_skill_files": { "type": "boolean", "description": "True if any output text contained 'skill' or 'SKILL.md' literals." },
        "inferred_identity": { "type": "boolean", "description": "True if Grader could guess which variant was with-Skill based on content (they MUST still grade on quality only)." }
      }
    }
  }
}
