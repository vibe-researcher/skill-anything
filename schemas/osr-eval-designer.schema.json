{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skill-anything.local/schemas/osr-eval-designer.schema.json",
  "title": "OSR — Eval Designer",
  "description": "Return schema for Eval Designer sub-agents. Typical size 800B-2KB. CRITICAL: Eval Designer runs in isolation (no access to skills/). isolation_env_path is filled by isolation_runner.py; Orchestrator compares it to its own view of workspace to ensure it is a distinct tmpdir/worktree.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "status",
    "agent_type",
    "agent_env",
    "surprises",
    "anomalies",
    "meta_observations",
    "eval_tasks_file",
    "task_ids",
    "skill_term_leakage_check",
    "isolation_env_path"
  ],
  "properties": {
    "status": { "enum": ["success", "partial", "failed", "schema_insufficient"] },
    "agent_type": { "const": "eval_designer" },
    "agent_env": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cwd", "wall_time_s"],
      "properties": {
        "cwd": { "type": "string" },
        "wall_time_s": { "type": "number", "minimum": 0 },
        "tool_use_count_self_report": { "type": "integer", "minimum": 0 }
      }
    },
    "surprises": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["short", "suggested_action", "severity"],
        "properties": {
          "short": { "type": "string", "maxLength": 120 },
          "suggested_action": { "type": "string", "maxLength": 200 },
          "severity": { "enum": ["low", "medium", "high"] },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "anomalies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim"],
        "properties": {
          "claim": { "type": "string", "maxLength": 200 },
          "evidence_path": { "type": "string" }
        }
      }
    },
    "meta_observations": { "type": "array", "items": { "type": "string", "maxLength": 200 } },
    "notes_path": { "type": "string" },
    "notes_topic_tags": { "type": "array", "items": { "type": "string" }, "maxItems": 10 },
    "requested_schema_extension": {
      "type": "object",
      "required": ["field_name", "field_type", "reason"],
      "properties": {
        "field_name": { "type": "string" },
        "field_type": { "type": "string" },
        "reason": { "type": "string", "maxLength": 500 }
      }
    },
    "extras": { "type": "object" },

    "eval_tasks_file": {
      "type": "string",
      "description": "Path (relative to workspace/) to the eval-tasks.json produced in the isolation env."
    },
    "task_ids": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
      "minItems": 1
    },
    "skill_term_leakage_check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["passed", "terms_found"],
      "properties": {
        "passed": { "type": "boolean" },
        "terms_found": { "type": "array", "items": { "type": "string" } },
        "check_source": { "type": "string", "description": "Path to the term blocklist used (maintained by Orchestrator)." }
      }
    },
    "discrimination_predictions": {
      "type": "array",
      "description": "Designer's prior on how much each task will distinguish with-Skill vs without-Skill. Orchestrator later compares to actual Grader gaps.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["task_id", "expected_gap"],
        "properties": {
          "task_id": { "type": "string" },
          "expected_gap": { "enum": ["low", "medium", "high"] },
          "rationale": { "type": "string", "maxLength": 200 }
        }
      }
    },
    "isolation_env_path": {
      "type": "string",
      "description": "Absolute path of the isolation env used. MUST NOT contain 'skills' as a component — enforced by isolation_runner.py preflight."
    }
  }
}
